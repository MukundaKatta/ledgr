{
  "expo": {
    "name": "Ledgr",
    "slug": "ledgr",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "ledgr",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#4f46e5",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.ledgr.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Ledgr uses your camera to scan receipts for expense tracking."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#4f46e5"
      },
      "package": "app.ledgr.mobile",
      "permissions": ["CAMERA"]
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-image-picker",
      "expo-notifications",
      "expo-secure-store"
    ]
  }
}
